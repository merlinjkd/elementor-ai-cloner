        {
          "id": "el-1776637247929-18",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "24/7 Uptime Monitoring",
            "header_size": "h3",
            "align": "center",
            "title_color": "rgb(39, 32, 99)",
